<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="10dp">

    <EditText
        android:id="@+id/edtNome"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Nome da receita"/>

    <Spinner
        android:id="@+id/spCategoria"
        android:layout_width="match_parent"
        android:layout_height="48dp"/>

    <EditText
        android:id="@+id/edtTempo"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:inputType="number"
        android:hint="Tempo em minutos"/>

    <EditText
        android:id="@+id/edtIngredientes"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Ingredientes"/>

    <Spinner
        android:id="@+id/spDificuldade"
        android:layout_width="match_parent"
        android:layout_height="48dp"/>

    <CheckBox
        android:id="@+id/checkFavorita"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Favorita"/>

    <Button
        android:id="@+id/btnSalvar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Salvar"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerReceitas"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

</LinearLayout>
